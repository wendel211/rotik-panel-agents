# Copie para .env e ajuste. O .env nunca é versionado.
# Todas estas variáveis são validadas por Zod no boot (src/config/env.ts).
# Se faltar alguma ou vier malformada, a API não sobe.

NODE_ENV=development
PORT=3333

# Precisa bater com o docker-compose.yml da raiz do projeto.
DATABASE_URL=postgresql://rotik:rotik_dev_only@localhost:5432/rotik

# Mínimo de 32 caracteres, validado no boot.
# Em produção, gere um valor aleatório e guarde no secret manager do provedor:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=troque_este_valor_por_um_segredo_aleatorio_de_dev
JWT_EXPIRES_IN=1d

# Origem do frontend (Etapa 3). Aceita lista separada por vírgula.
CORS_ORIGIN=http://localhost:5173

LOG_LEVEL=info

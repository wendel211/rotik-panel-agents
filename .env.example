# Configuração exclusiva do PostgreSQL local usado pelo Docker Compose.
# Copie para .env na raiz. O arquivo .env é ignorado pelo Git.
#
# Estes valores são somente exemplos de desenvolvimento. Nunca reutilize a
# senha em staging/produção; nesses ambientes use o secret manager do provedor.
POSTGRES_USER=rotik
POSTGRES_PASSWORD=rotik_dev_only
POSTGRES_DB=rotik
POSTGRES_PORT=5432
